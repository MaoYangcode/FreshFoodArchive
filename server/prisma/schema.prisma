// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id              Int      @id @default(autoincrement())
  name            String?
  avatar          String?  @db.Text
  householdSize   Int      @default(2)
  dietPreferences Json?
  avoidances      Json?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  ingredients Ingredient[]
  favorites   FavoriteRecipe[]
  basketItems BasketItem[]
  expiryReminderSetting ExpiryReminderSetting?
  expiryReminderLogs    ExpiryReminderLog[]
  shelfLifeSetting      ShelfLifeSetting?
}

model Ingredient {
  id         Int      @id @default(autoincrement())
  name       String
  category   String?
  quantity   Float
  unit       String?
  location   String?
  expireDate DateTime?
  createdAt  DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  takeoutRecords TakeoutRecord[]
}

model TakeoutRecord {
  id        Int      @id @default(autoincrement())
  quantity  Float
  time      DateTime @default(now())

  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Recipe {
  id         Int      @id @default(autoincrement())
  name       String
  difficulty String?
  duration   Int?
  steps      Json
  createdAt  DateTime @default(now())

  ingredients RecipeIngredient[]
  favorites   FavoriteRecipe[]
}

model RecipeIngredient {
  id Int @id @default(autoincrement())

  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  ingredientName String
  quantity       Float?
  unit           String?
}

model FavoriteRecipe {
  id Int @id @default(autoincrement())

  userId   Int
  recipeId Int

  user   User   @relation(fields: [userId], references: [id])
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@unique([userId, recipeId])
}

model BasketItem {
  id             Int      @id @default(autoincrement())
  userId         Int
  name           String
  normalizedName String
  quantity       Float
  unit           String?
  category       String?
  status         String   @default("todo")
  sourceRecipeName String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status, normalizedName])
}

model ExpiryReminderSetting {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  enabled         Boolean  @default(true)
  remindTime      String   @default("09:00")
  defaultDays     Int      @default(2)
  rules           Json?
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ExpiryReminderLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  source    String   @default("scheduled")
  triggerAt DateTime @default(now())
  total     Int      @default(0)
  summary   Json?
  items     Json?

  user User @relation(fields: [userId], references: [id])
}

model ShelfLifeSetting {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  defaultDays Int      @default(7)
  rules       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

PORT=3000

# Database fields used by Prisma adapter in src/prisma/prisma.service.ts
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_NAME=fresh_food_archive

# Database URL used by prisma.config.ts (Prisma CLI)
DATABASE_URL="mysql://root:123456@127.0.0.1:3306/fresh_food_archive"

# Optional: future AI integration
DASHSCOPE_API_KEY=
